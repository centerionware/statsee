<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<style>
body { background:#0b0f14; color:white; font-family:sans-serif; margin:0 }
.card { background:#11161c; padding:16px; margin:16px; border-radius:10px }
.big { font-size:28px }
canvas { width:100%; height:150px }
button { padding:10px; background:#1f6feb; color:white; border:none }
</style>
</head>
<body>

<div class="card">
  CPU: <span id="cpu"></span>
  <canvas id="cpuChart"></canvas>
</div>

<div class="card">
  Speedtest<br>
  Latency: <span id="latency"></span><br>
  <div class="big" id="speed">0</div>
  <canvas id="gauge"></canvas>
  <button onclick="start()">Start</button>
</div>

<script>
const ws = new WebSocket((location.protocol==="https:"?"wss://":"ws://")+location.host+"/ws");

let cpuData=[];

ws.onmessage = e => {
  const d = JSON.parse(e.data);

  if(d.type==="stats"){
    document.getElementById("cpu").innerText=d.cpu.toFixed(1)+"%";
    cpuData.push(d.cpu); if(cpuData.length>50) cpuData.shift();
    draw("cpuChart",cpuData);
  }

  if(d.type==="latency"){
    document.getElementById("latency").innerText=d.value+" ms";
  }

  if(d.type==="download"||d.type==="upload"){
    document.getElementById("speed").innerText=d.value.toFixed(2)+" MB/s";
    drawGauge(d.value);
  }
};

function start(){
  ws.send(JSON.stringify({type:"speedtest"}));
}

function draw(id,data){
  const c=document.getElementById(id);
  const ctx=c.getContext("2d");
  ctx.clearRect(0,0,c.width,c.height);
  ctx.beginPath();
  data.forEach((v,i)=>{
    let x=i*(c.width/data.length);
    let y=c.height-(v/100)*c.height;
    i?ctx.lineTo(x,y):ctx.moveTo(x,y);
  });
  ctx.stroke();
}

function drawGauge(v){
  const c=document.getElementById("gauge");
  const ctx=c.getContext("2d");
  ctx.clearRect(0,0,c.width,c.height);

  let max=200;
  let angle=(v/max)*Math.PI;

  ctx.beginPath();
  ctx.arc(150,150,100,Math.PI,Math.PI+angle);
  ctx.stroke();
}
</script>

</body>
</html>