<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>StatSee Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.tailwindcss.com"></script>
<style>
body {background:#121212;color:#fff;font-family:sans-serif;}
.card {background:#1f1f1f;border-radius:0.75rem;padding:1rem;margin:1rem;}
button {background:#3b82f6;color:white;font-weight:bold;padding:0.5rem 1rem;border-radius:0.5rem;cursor:pointer;}
</style>
</head>
<body class="min-h-screen p-4">
<h1 class="text-3xl font-bold mb-4">StatSee Dashboard</h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">

  <div class="card">
    <h2 class="text-xl font-semibold mb-2">CPU Load</h2>
    <canvas id="cpuChart" height="100"></canvas>
  </div>

  <div class="card">
    <h2 class="text-xl font-semibold mb-2">RAM Usage (MB)</h2>
    <canvas id="ramChart" height="100"></canvas>
  </div>

  <div class="card">
    <h2 class="text-xl font-semibold mb-2">Disk I/O (MB)</h2>
    <canvas id="diskChart" height="100"></canvas>
  </div>

  <div class="card">
    <h2 class="text-xl font-semibold mb-2">Network Traffic (MB/s)</h2>
    <div id="netTotals" class="mb-2 text-sm text-gray-300"></div>
    <canvas id="netChart" height="100"></canvas>
  </div>

  <div class="card md:col-span-2">
    <h2 class="text-xl font-semibold mb-2">Speed Test</h2>
    <button onclick="startSpeedTest()">Run Speed Test</button>
    <canvas id="speedChart" height="100" class="mt-2"></canvas>
  </div>

</div>

<script>
let ws = new WebSocket(`ws://${location.host}/ws`);

const cpuChart = new Chart(document.getElementById('cpuChart').getContext('2d'), {
  type:'line',
  data:{labels:[],datasets:[{label:'CPU %',data:[],borderColor:'red',fill:false}]},
  options:{animation:false,scales:{y:{min:0,max:100}}}
});

const ramChart = new Chart(document.getElementById('ramChart').getContext('2d'), {
  type:'line',
  data:{labels:[],datasets:[
    {label:'Used MB',data:[],borderColor:'orange',fill:false},
    {label:'Free MB',data:[],borderColor:'green',fill:false}
  ]},
  options:{animation:false,scales:{y:{min:0}}}
});

const diskChart = new Chart(document.getElementById('diskChart').getContext('2d'), {
  type:'line',
  data:{labels:[],datasets:[
    {label:'Read MB',data:[],borderColor:'cyan',fill:false},
    {label:'Write MB',data:[],borderColor:'magenta',fill:false}
  ]},
  options:{animation:false,scales:{y:{min:0}}}
});

const netChart = new Chart(document.getElementById('netChart').getContext('2d'), {
  type:'line',
  data:{labels:[],datasets:[
    {label:'Ingress MB/s',data:[],borderColor:'lime',fill:false},
    {label:'Egress MB/s',data:[],borderColor:'yellow',fill:false}
  ]},
  options:{animation:false,scales:{y:{min:0}}}
});

const speedChart = new Chart(document.getElementById('speedChart').getContext('2d'), {
  type:'line',
  data:{labels:[],datasets:[
    {label:'Download MB/s',data:[],borderColor:'blue',fill:false},
    {label:'Upload MB/s',data:[],borderColor:'red',fill:false},
    {label:'Latency ms',data:[],borderColor:'green',fill:false}
  ]},
  options:{animation:false,scales:{y:{min:0}}}
});

function updateNetTotals() {
  fetch('/api/bandwidth/daily').then(r=>r.json()).then(d=>{
    fetch('/api/bandwidth/monthly').then(rm=>rm.json()).then(m=>{
      let txt = "";
      for(let iface in d){
        txt += `<b>${iface}</b>: Daily: In ${d[iface].in.toFixed(2)}GB / Out ${d[iface].out.toFixed(2)}GB, `;
        txt += `Monthly: In ${m[iface]?.in?.toFixed(2)||0}GB / Out ${m[iface]?.out?.toFixed(2)||0}GB<br>`;
      }
      document.getElementById('netTotals').innerHTML = txt;
    });
  });
}

ws.onopen = ()=>updateNetTotals();
setInterval(updateNetTotals, 60*1000);

ws.onmessage = e=>{
  let msg=JSON.parse(e.data);
  if(msg.type==='stats'){
    const ts=new Date(msg.ts*1000).toLocaleTimeString();

    // CPU
    cpuChart.data.labels.push(ts);
    cpuChart.data.datasets[0].data.push(msg.cpu);
    if(cpuChart.data.labels.length>30){cpuChart.data.labels.shift();cpuChart.data.datasets[0].data.shift();}
    cpuChart.update();

    // RAM
    ramChart.data.labels.push(ts);
    ramChart.data.datasets[0].data.push(msg.ram.used);
    ramChart.data.datasets[1].data.push(msg.ram.free);
    if(ramChart.data.labels.length>30){ramChart.data.labels.shift();ramChart.data.datasets[0].data.shift();ramChart.data.datasets[1].data.shift();}
    ramChart.update();

    // Disk
    let totalRead=0,totalWrite=0;
    for(let k in msg.disk){totalRead+=msg.disk[k].read_io/1024/1024; totalWrite+=msg.disk[k].write_io/1024/1024;}
    diskChart.data.labels.push(ts);
    diskChart.data.datasets[0].data.push(totalRead);
    diskChart.data.datasets[1].data.push(totalWrite);
    if(diskChart.data.labels.length>30){diskChart.data.labels.shift();diskChart.data.datasets[0].data.shift();diskChart.data.datasets[1].data.shift();}
    diskChart.update();

    // Network
    let totalIn=0,totalOut=0;
    for(let k in msg.net){totalIn+=msg.net[k].rate_recv; totalOut+=msg.net[k].rate_sent;}
    netChart.data.labels.push(ts);
    netChart.data.datasets[0].data.push(totalIn);
    netChart.data.datasets[1].data.push(totalOut);
    if(netChart.data.labels.length>30){netChart.data.labels.shift();netChart.data.datasets[0].data.shift();netChart.data.datasets[1].data.shift();}
    netChart.update();
  } else if(msg.type==='download'||msg.type==='upload'||msg.type==='latency'){
    const ts=new Date().toLocaleTimeString();
    speedChart.data.labels.push(ts);
    speedChart.data.datasets[0].data.push(msg.type==='download'?msg.value:null);
    speedChart.data.datasets[1].data.push(msg.type==='upload'?msg.value:null);
    speedChart.data.datasets[2].data.push(msg.type==='latency'?msg.value:null);
    if(speedChart.data.labels.length>20){speedChart.data.labels.shift();speedChart.data.datasets[0].data.shift();speedChart.data.datasets[1].data.shift();speedChart.data.datasets[2].data.shift();}
    speedChart.update();
  }
};

function startSpeedTest(){ws.send(JSON.stringify({type:'speedtest'}));}
</script>
</body>
</html>